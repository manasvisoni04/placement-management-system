<%- include('../partials/header') %>

<div class="row mb-4">
    <div class="col-md-8">
        <h2>Admin Dashboard</h2>
        <p class="text-muted">Manage companies, skills, placement drives, and notifications from one place.</p>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3">
        <div class="card bg-primary text-white border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <h3 class="display-5 fw-bold"><%= companies.length %></h3>
                <p class="mb-0 fs-5 text-white-50">Companies</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-success text-white border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <h3 class="display-5 fw-bold"><%= drives.length %></h3>
                <p class="mb-0 fs-5 text-white-50">Placement Drives</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-info text-white border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <h3 class="display-5 fw-bold"><%= students.length %></h3>
                <p class="mb-0 fs-5 text-white-50">Students</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card bg-warning text-dark border-0 shadow-sm">
            <div class="card-body text-center py-4">
                <h3 class="display-5 fw-bold"><%= notifications.length %></h3>
                <p class="mb-0 fs-5 text-dark-50">Notifications</p>
            </div>
        </div>
    </div>
</div>

<!-- Tabs for Management -->
<ul class="nav nav-tabs mb-4 border-0" id="adminTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active fw-bold text-dark border-0 border-bottom border-primary border-3 bg-transparent" id="companies-tab" data-bs-toggle="tab" data-bs-target="#companies" type="button" role="tab">Companies</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-muted border-0 bg-transparent" id="skills-tab" data-bs-toggle="tab" data-bs-target="#skills" type="button" role="tab">Skills</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-muted border-0 bg-transparent" id="drives-tab" data-bs-toggle="tab" data-bs-target="#drives" type="button" role="tab">Drives</button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link fw-bold text-muted border-0 bg-transparent" id="notifs-tab" data-bs-toggle="tab" data-bs-target="#notifs" type="button" role="tab">Notifications</button>
    </li>
</ul>

<div class="tab-content" id="adminTabsContent">
    
    <!-- COMPANIES TAB -->
    <div class="tab-pane fade show active" id="companies" role="tabpanel">
        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-white">Add New Company</div>
                    <div class="card-body">
                        <form action="/admin/company/add" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Company Name</label>
                                <input type="text" name="company_name" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Job Role</label>
                                <input type="text" name="job_role" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Package (CTC)</label>
                                <input type="text" name="package" class="form-control" placeholder="e.g. 10 LPA" required>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">Location</label>
                                <input type="text" name="location" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Add Company</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-white">Company Directory</div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>ID</th>
                                        <th>Name</th>
                                        <th>Role</th>
                                        <th>Package</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (companies.length === 0) { %>
                                        <tr><td colspan="5" class="text-center py-4">No companies found.</td></tr>
                                    <% } %>
                                    <% companies.forEach(c => { %>
                                    <tr>
                                        <td>#<%= c.company_id %></td>
                                        <td class="fw-bold"><%= c.company_name %></td>
                                        <td><%= c.job_role %></td>
                                        <td><span class="badge bg-success">₹ <%= c.package %></span></td>
                                        <td>
                                            <form action="/admin/company/delete/<%= c.company_id %>" method="POST" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SKILLS TAB -->
    <div class="tab-pane fade" id="skills" role="tabpanel">
        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-white">Add Skill Requirement</div>
                    <div class="card-body">
                        <form action="/admin/skill/add" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Select Company</label>
                                <select name="company_id" class="form-select" required>
                                    <option value="" disabled selected>Choose a company...</option>
                                    <% companies.forEach(c => { %>
                                        <option value="<%= c.company_id %>"><%= c.company_name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">Required Skill</label>
                                <input type="text" name="skill_name" class="form-control" placeholder="e.g. React.js, Python" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Add Skill</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-white">Company Skills list</div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush rounded-bottom">
                            <% if (skills.length === 0) { %>
                                <li class="list-group-item text-center py-4 text-muted">No skills mapped yet.</li>
                            <% } %>
                            <% skills.forEach(s => { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center py-3">
                                    <span>
                                        <span class="fw-bold text-primary"><%= s.company_name %></span> requires 
                                        <strong><%= s.skill_name %></strong>
                                    </span>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- DRIVES TAB -->
    <div class="tab-pane fade" id="drives" role="tabpanel">
        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-white">Create Placement Drive</div>
                    <div class="card-body">
                        <form action="/admin/drive/add" method="POST">
                            <div class="mb-3">
                                <label class="form-label">Select Company</label>
                                <select name="company_id" class="form-select" required>
                                    <option value="" disabled selected>Choose...</option>
                                    <% companies.forEach(c => { %>
                                        <option value="<%= c.company_id %>"><%= c.company_name %></option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Min. CGPA Eligibility</label>
                                <input type="number" step="0.01" min="0" max="10" name="eligibility_cgpa" class="form-control" required>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Timing</label>
                                <input type="text" name="timing" class="form-control" placeholder="e.g. 10:00 AM">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Venue</label>
                                <input type="text" name="venue" class="form-control" placeholder="e.g. Virtual OR Room 101">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Rounds of Procedure</label>
                                <textarea name="rounds_of_procedure" class="form-control" rows="2" placeholder="e.g. 1. Aptitude 2. Coding 3. HR"></textarea>
                            </div>
                            <div class="mb-4">
                                <label class="form-label">Application Deadline</label>
                                <input type="date" name="deadline" class="form-control" required>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">Create Drive</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-white">Active & Past Drives</div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0 align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Company</th>
                                        <th>Req. CGPA</th>
                                        <th>Deadline</th>
                                        <th>Status</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (drives.length === 0) { %>
                                        <tr><td colspan="5" class="text-center py-4">No placement drives found.</td></tr>
                                    <% } %>
                                    <% drives.forEach(d => { %>
                                    <tr>
                                        <td class="fw-bold"><%= d.company_name %></td>
                                        <td><%= d.eligibility_cgpa %>+</td>
                                        <td><%= d.deadline %></td>
                                        <td>
                                            <% if (d.status === 'Open') { %>
                                                <span class="badge bg-success"><i class="bi bi-circle-fill small me-1"></i>Open</span>
                                            <% } else { %>
                                                <span class="badge bg-secondary">Closed</span>
                                            <% } %>
                                        </td>
                                        <td>
                                            <form action="/admin/drive/status/<%= d.drive_id %>" method="POST" class="d-inline mb-0">
                                                <select name="status" class="form-select form-select-sm d-inline-block w-auto" onchange="this.form.submit()">
                                                    <option value="Open" <%= d.status==='Open'?'selected':'' %>>Open</option>
                                                    <option value="Closed" <%= d.status==='Closed'?'selected':'' %>>Close</option>
                                                </select>
                                            </form>
                                            <form action="/admin/drive/delete/<%= d.drive_id %>" method="POST" class="d-inline mb-0 ms-1" onsubmit="return confirm('Delete this placement drive?');">
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1"><i class="bi bi-trash"></i> Delete</button>
                                            </form>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- NOTIFICATIONS TAB -->
    <div class="tab-pane fade" id="notifs" role="tabpanel">
        <div class="row">
            <div class="col-md-4">
                <div class="card">
                    <div class="card-header bg-white">Post Update</div>
                    <div class="card-body">
                        <form action="/admin/notification/add" method="POST">
                            <div class="mb-4">
                                <label class="form-label">Notification Message</label>
                                <textarea name="message" class="form-control" rows="4" placeholder="Enter important update for students..." required></textarea>
                            </div>
                            <button type="submit" class="btn btn-warning w-100 fw-bold">Broadcast Notification</button>
                        </form>
                    </div>
                </div>
            </div>
            <div class="col-md-8">
                <div class="card">
                    <div class="card-header bg-white">Recent Broadcasts</div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush rounded-bottom">
                            <% if (notifications.length === 0) { %>
                                <li class="list-group-item text-center py-4 text-muted">No notifications posted yet.</li>
                            <% } %>
                            <% notifications.forEach(n => { %>
                                <li class="list-group-item py-3">
                                    <div class="d-flex w-100 justify-content-between">
                                        <h6 class="mb-1 text-dark fw-bold"><i class="text-warning">🔔</i> Placement Update</h6>
                                        <small class="text-muted"><%= n.date %></small>
                                    </div>
                                    <p class="mb-1 text-secondary"><%= n.message %></p>
                                </li>
                            <% }) %>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- Auto Tab persistence script to keep the active tab on reload -->
<script>
    document.addEventListener("DOMContentLoaded", function () {
        const triggerTabList = [].slice.call(document.querySelectorAll('#adminTabs button'))
        triggerTabList.forEach(function (triggerEl) {
            triggerEl.addEventListener('click', function (event) {
                localStorage.setItem('activeAdminTab', event.target.id);
                // Update UI visually
                document.querySelectorAll('#adminTabs .nav-link').forEach(el => {
                    el.classList.remove('active', 'text-dark', 'border-bottom', 'border-primary', 'border-3');
                    el.classList.add('text-muted');
                });
                event.target.classList.remove('text-muted');
                event.target.classList.add('active', 'text-dark', 'border-bottom', 'border-primary', 'border-3');
            })
        });

        // Restore tab
        let activeTabId = localStorage.getItem('activeAdminTab');
        if (activeTabId) {
            let selectedTab = new bootstrap.Tab(document.querySelector('#' + activeTabId));
            selectedTab.show();
            
            // Visual reset
            document.querySelectorAll('#adminTabs .nav-link').forEach(el => {
                el.classList.remove('active', 'text-dark', 'border-bottom', 'border-primary', 'border-3');
                el.classList.add('text-muted');
            });
            let tabToSelect = document.getElementById(activeTabId);
            tabToSelect.classList.remove('text-muted');
            tabToSelect.classList.add('active', 'text-dark', 'border-bottom', 'border-primary', 'border-3');
        }
    });
</script>

<%- include('../partials/footer') %>
