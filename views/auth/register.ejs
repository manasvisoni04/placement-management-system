<%- include('../partials/header') %>

<div class="auth-container">
    <div class="card p-4">
        <div class="auth-header">
            <h2>Create an Account</h2>
            <p>Register as a student to explore placement opportunities</p>
        </div>
        
        <form action="/auth/register" method="POST">
            <div class="mb-3">
                <label for="name" class="form-label">Full Name</label>
                <input type="text" class="form-control" id="name" name="name" placeholder="John Doe" required>
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label for="branch" class="form-label">Branch/Department</label>
                    <input type="text" class="form-control" id="branch" name="branch" placeholder="e.g. CSE, IT, ECE" required>
                </div>
                <div class="col-md-6 mt-3 mt-md-0">
                    <label for="cgpa" class="form-label">Current CGPA</label>
                    <input type="number" step="0.01" min="0" max="10" class="form-control" id="cgpa" name="cgpa" placeholder="8.50" required>
                </div>
            </div>
            
            <div class="mb-3">
                <label for="email" class="form-label">College Email Address</label>
                <input type="email" class="form-control" id="email" name="email" placeholder="john@college.edu" required>
            </div>
            
            <div class="mb-4">
                <label for="password" class="form-label">Password</label>
                <input type="password" class="form-control" id="password" name="password" placeholder="Create a strong password" required minlength="6">
            </div>
            
            <button type="submit" class="btn btn-primary w-100 py-2">Register</button>
        </form>
        
        <div class="text-center mt-4">
            <p class="text-muted">Already have an account? <a href="/auth/login" class="text-decoration-none fw-bold">Login here</a></p>
        </div>
    </div>
</div>

<%- include('../partials/footer') %>
